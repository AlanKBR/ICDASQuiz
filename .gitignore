# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Ambiente virtual
venv/
.venv/
.venv-*/
env/
env_*/

# Variáveis de ambiente (nunca commitar)
.env
.env.local

# Banco de dados SQLite (icdas.db é versionado — dados iniciais do deploy)
# Apenas os arquivos temporários do WAL mode:
*.db-wal
*.db-shm
*.sqlite3

# Imagens: apenas WebP enviadas ao repositório.
# Os PNGs originais ficam somente na máquina do desenvolvedor.
static/imagens/*.png
static/imagens/*.jpg
static/imagens/*.jpeg

# Pasta de imagens na raiz (duplicata de static/imagens/ — não é servida pelo Flask)
/imagens/

# Sistema operacional
.DS_Store
Thumbs.db

# IDEs
.vscode/settings.json
# (extensions.json é commitado para recomendar extensões aos colaboradores)
.idea/

# Logs
*.log
